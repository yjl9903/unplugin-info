{
  "name": "unplugin-info",
  "version": "1.3.2",
  "description": "Export build information as virutal module",
  "keywords": [
    "debug",
    "config",
    "unplugin",
    "build",
    "vite",
    "vite-plugin",
    "webpack",
    "rspack",
    "git",
    "CI"
  ],
  "homepage": "https://yjl9903.github.io/unplugin-info/",
  "bugs": {
    "url": "https://github.com/yjl9903/unplugin-info/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yjl9903/unplugin-info.git"
  },
  "license": "MIT",
  "author": "XLor",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./*": "./*",
    "./astro": {
      "types": "./dist/astro.d.mts",
      "import": "./dist/astro.mjs",
      "require": "./dist/astro.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs",
      "require": "./dist/vite.cjs"
    },
    "./webpack": {
      "types": "./dist/webpack.d.mts",
      "import": "./dist/webpack.mjs",
      "require": "./dist/webpack.cjs"
    },
    "./rollup": {
      "types": "./dist/rollup.d.mts",
      "import": "./dist/rollup.mjs",
      "require": "./dist/rollup.cjs"
    },
    "./esbuild": {
      "types": "./dist/esbuild.d.mts",
      "import": "./dist/esbuild.mjs",
      "require": "./dist/esbuild.cjs"
    },
    "./nuxt": {
      "types": "./dist/nuxt.d.mts",
      "import": "./dist/nuxt.mjs",
      "require": "./dist/nuxt.cjs"
    },
    "./client": {
      "types": "./client.d.ts"
    },
    "./rspack": {
      "types": "./dist/rspack.d.mts",
      "import": "./dist/rspack.mjs",
      "require": "./dist/rspack.cjs"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./*"
      ]
    }
  },
  "files": [
    "dist",
    "*.d.mts",
    "*.d.ts"
  ],
  "scripts": {
    "build": "tsdown",
    "build:nuxt": "pnpm -C examples/nuxt build",
    "build:rspack": "pnpm -C examples/rspack build",
    "build:vite": "pnpm -C examples/vite build",
    "build:webpack": "pnpm -C examples/webpack build",
    "dev": "tsdown --watch",
    "dev:nuxt": "pnpm -C examples/nuxt dev",
    "dev:rspack": "pnpm -C examples/rspack dev",
    "dev:vite": "pnpm -C examples/vite dev",
    "dev:webpack": "pnpm -C examples/webpack dev",
    "format": "prettier --write examples src",
    "release": "bumpp package.json examples/*/package.json --commit --push --tag",
    "test": "vitest",
    "test:ci": "vitest --run",
    "typecheck": "tsc --noEmit",
    "preversion": "pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "ci-info": "^4.4.0",
    "git-url-parse": "^16.1.0",
    "simple-git": "^3.36.0",
    "unplugin": "^3.3.0"
  },
  "devDependencies": {
    "@nuxt/kit": "^4.5.0",
    "@nuxt/schema": "^4.5.0",
    "@types/node": "^24.13.3",
    "bumpp": "^12.0.0",
    "chalk": "^5.6.2",
    "date-fns": "^4.4.0",
    "fast-glob": "^3.3.3",
    "prettier": "^3.9.6",
    "rollup": "^4.62.2",
    "tsdown": "^0.22.13",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "webpack": "^5.108.4"
  },
  "peerDependencies": {
    "@nuxt/kit": ">=3",
    "@nuxt/schema": ">=3",
    "@rspack/core": "*",
    "esbuild": "*",
    "rollup": "^2 || ^3 || ^4",
    "vite": ">=3.2.7",
    "webpack": "^4 || ^5"
  },
  "peerDependenciesMeta": {
    "@nuxt/kit": {
      "optional": true
    },
    "@nuxt/schema": {
      "optional": true
    },
    "@rspack/core": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    },
    "rollup": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "packageManager": "pnpm@11.15.1"
}
